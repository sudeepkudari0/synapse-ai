{
  "name": "synapse-ai",
  "version": "1.0.0",
  "description": "AI-powered interview assistant with real-time screen analysis and intelligent suggestions",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"bun run build:electron\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node build-preload.cjs",
    "build:all": "bun run build && bun run build:electron",
    "dist": "bun run build:all && electron-builder",
    "dist:win": "bun run build:all && electron-builder --win",
    "start": "electron .",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:whisper-gpu": "bun run scripts/test-whisper-gpu.ts",
    "test:whisper-benchmark": "bun run scripts/benchmark-whisper-pipeline.ts",
    "test:whisper-stream": "bun run scripts/test-whisper-streaming.ts",
    "setup:whisper": "powershell -ExecutionPolicy Bypass -File scripts/setup-whisper.ps1"
  },
  "keywords": [
    "electron",
    "react",
    "vite",
    "overlay"
  ],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.synapse.ai",
    "productName": "Synapse AI",
    "asar": false,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "native/whisper",
        "to": "whisper",
        "filter": [
          "**/*",
          "!models/**/*"
        ]
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Synapse AI"
    },
    "portable": {
      "artifactName": "SynapseAI-Portable-${version}.${ext}"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.1.0",
    "electron": "33",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.1",
    "playwright": "^1.57.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@ricky0123/vad-web": "^0.0.30",
    "@types/node": "^25.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "fill-range": "^7.1.1",
    "lucide-react": "^0.561.0",
    "onnxruntime-web": "^1.24.3",
    "openai": "^6.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.13"
  }
}